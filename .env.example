# Red Team / Blue Team Test Configuration
# Copy this file to .env and update with your target endpoints.

# Agent Fabric / Orchestration Endpoints
# Replace these with your actual deployment URLs.
RTBT_APP1_URL=https://your-orchestration-app.cloudhub.io
RTBT_APP2_URL=https://your-turnaround-app.cloudhub.io
RTBT_APP3_URL=https://your-order-to-cash-app.cloudhub.io
RTBT_BROKER_URL=https://your-broker-runtime.cloudhub.io
RTBT_MCP_SAFETY_URL=https://your-safety-mcp-server.cloudhub.io
RTBT_MCP_CONTEXT_URL=https://your-context-mcp-server.cloudhub.io
RTBT_MCP_DOCUMENT_URL=https://your-document-mcp-server.cloudhub.io

# Test Parameters (optional overrides)
RTBT_TTD_TARGET=3.0
RTBT_BLOCK_ACCURACY_TARGET=0.99
RTBT_FALSE_POSITIVE_TARGET=0.03
